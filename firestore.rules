rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isEventAdmin(eventId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/events/$(eventId)/admins/$(request.auth.uid));
    }

    function isEventOwner(eventId) {
      return isEventAdmin(eventId)
        && get(/databases/$(database)/documents/events/$(eventId)/admins/$(request.auth.uid)).data.role == "owner";
    }

    function isOptionalString(field, maxSize) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string && request.resource.data[field].size() <= maxSize);
    }

    function isOptionalEnum(field, values) {
      return !(field in request.resource.data)
        || request.resource.data[field] in values;
    }

    function hasValidTermsAcceptance() {
      return request.resource.data.termsAcceptance is map
        && request.resource.data.termsAcceptance.keys().hasOnly([
          "adhesionTermAccepted",
          "privacyPolicyAccepted",
          "platformTermsAccepted",
          "financialTermsAccepted",
          "imageUseAuthorized",
          "souvenirsInfoAccepted",
          "acceptedAt",
          "userAgent",
          "adhesionTermVersion",
          "privacyPolicyVersion",
          "platformTermsVersion",
          "financialTermsVersion",
          "imageUseTermVersion",
          "souvenirsTermVersion"
        ])
        && request.resource.data.termsAcceptance.adhesionTermAccepted == true
        && request.resource.data.termsAcceptance.privacyPolicyAccepted == true
        && request.resource.data.termsAcceptance.platformTermsAccepted == true
        && request.resource.data.termsAcceptance.financialTermsAccepted == true;
    }

    function hasValidOfficialKit() {
      return request.resource.data.officialKit is map
        && request.resource.data.officialKit.keys().hasOnly([
          "interest",
          "shirtSize",
          "jacketSize",
          "pantsSize",
          "heightCm",
          "approximateWeightKg",
          "needsSpecialSize",
          "wantsNameCustomization",
          "customizationName",
          "additionalKitsInterest",
          "notes"
        ])
        && request.resource.data.officialKit.interest in ["yes", "maybe", "no"];
    }

    function hasValidPublicParticipantShape() {
      return request.resource.data.keys().hasOnly([
          "name",
          "nickname",
          "email",
          "phone",
          "instagram",
          "linkedin",
          "birthDate",
          "currentFunction",
          "zipCode",
          "address",
          "city",
          "state",
          "country",
          "willAttend",
          "isFromOutOfState",
          "guestsCount",
          "needsHotelInfo",
          "needsTransportInfo",
          "wantsToHelpCommittee",
          "notes",
          "paymentStatus",
          "totalPaid",
          "officialKit",
          "termsAcceptance",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "name",
          "phone",
          "willAttend",
          "guestsCount",
          "needsHotelInfo",
          "needsTransportInfo",
          "paymentStatus",
          "totalPaid",
          "officialKit",
          "termsAcceptance",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 120
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 10
        && request.resource.data.phone.size() <= 40
        && request.resource.data.willAttend in ["yes", "maybe", "no"]
        && request.resource.data.guestsCount is number
        && request.resource.data.guestsCount >= 0
        && request.resource.data.guestsCount <= 20
        && request.resource.data.needsHotelInfo is bool
        && request.resource.data.needsTransportInfo is bool
        && request.resource.data.paymentStatus == "not_started"
        && request.resource.data.totalPaid == 0
        && isOptionalString("email", 160)
        && isOptionalString("nickname", 80)
        && isOptionalString("instagram", 80)
        && isOptionalString("linkedin", 160)
        && isOptionalString("notes", 1500)
        && hasValidOfficialKit()
        && hasValidTermsAcceptance();
    }

    function hasValidPublicSouvenirInterestShape() {
      return request.resource.data.keys().hasOnly([
          "participantId",
          "participantName",
          "warName",
          "contactPhone",
          "contactEmail",
          "souvenirId",
          "souvenirName",
          "souvenirCategory",
          "quantity",
          "shirtSize",
          "pantsSize",
          "jacketSize",
          "notes",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAll([
          "participantId",
          "participantName",
          "contactPhone",
          "souvenirId",
          "souvenirName",
          "quantity",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.participantId is string
        && request.resource.data.participantName is string
        && request.resource.data.participantName.size() >= 3
        && request.resource.data.participantName.size() <= 120
        && request.resource.data.contactPhone is string
        && request.resource.data.contactPhone.size() >= 10
        && request.resource.data.contactPhone.size() <= 40
        && request.resource.data.souvenirId is string
        && request.resource.data.souvenirId.size() >= 1
        && request.resource.data.souvenirId.size() <= 120
        && request.resource.data.souvenirName is string
        && request.resource.data.souvenirName.size() >= 1
        && request.resource.data.souvenirName.size() <= 160
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 1
        && request.resource.data.quantity <= 99
        && request.resource.data.status == "pending"
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() <= 40
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedAt.size() <= 40
        && isOptionalString("warName", 80)
        && isOptionalString("contactEmail", 160)
        && isOptionalEnum("souvenirCategory", ["kit", "shirt", "pants", "mug", "cap", "patch", "other"])
        && isOptionalEnum("shirtSize", ["PP", "P", "M", "G", "GG", "XG", "XGG", "SPECIAL"])
        && isOptionalEnum("pantsSize", ["PP", "P", "M", "G", "GG", "XG", "XGG", "SPECIAL"])
        && isOptionalEnum("jacketSize", ["PP", "P", "M", "G", "GG", "XG", "XGG", "SPECIAL"])
        && isOptionalString("notes", 500);
    }

    function hasValidPublicStatsShape(eventId) {
      return request.resource.data.keys().hasOnly([
          "confirmedCount",
          "eventId",
          "updatedAt"
        ])
        && request.resource.data.confirmedCount is number
        && request.resource.data.confirmedCount >= 0
        && request.resource.data.eventId is string
        && request.resource.data.eventId == eventId
        && request.resource.data.eventId.size() <= 120
        && (!("updatedAt" in request.resource.data)
          || request.resource.data.updatedAt is timestamp
          || request.resource.data.updatedAt is string);
    }

    function requestedSouvenirIsAvailable(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId)/souvenirs/$(request.resource.data.souvenirId))
        && get(/databases/$(database)/documents/events/$(eventId)/souvenirs/$(request.resource.data.souvenirId)).data.available == true;
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isEventAdmin(eventId);

      match /admins/{adminId} {
        allow read: if isEventAdmin(eventId);
        allow create, update, delete: if isEventOwner(eventId);
      }

      match /participants/{participantId} {
        allow create: if isEventAdmin(eventId) || hasValidPublicParticipantShape();
        allow read, update, delete: if isEventAdmin(eventId);
      }

      match /publicStats/{statsId} {
        allow get, list: if true;
        allow create, update: if isEventAdmin(eventId) && hasValidPublicStatsShape(eventId);
        allow delete: if isEventAdmin(eventId);
      }

      match /transactions/{transactionId} {
        allow read: if isEventAdmin(eventId) || resource.data.isPublic == true;
        allow create, update, delete: if isEventAdmin(eventId);
      }

      match /souvenirs/{souvenirId} {
        allow read: if true;
        allow create, update, delete: if isEventAdmin(eventId);
      }

      match /souvenirInterests/{interestId} {
        allow create: if isEventAdmin(eventId)
          || (hasValidPublicSouvenirInterestShape() && requestedSouvenirIsAvailable(eventId));
        allow read, update, delete: if isEventAdmin(eventId);
      }

      match /schedule/{scheduleId} {
        allow read: if isEventAdmin(eventId) || resource.data.isPublic == true;
        allow create, update, delete: if isEventAdmin(eventId);
      }

      match /{collection}/{document=**} {
        allow read, write: if isEventAdmin(eventId);
      }
    }
  }
}
